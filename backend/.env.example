# ── RenderFast Environment Variables ──────────────────────────────────────────
#
# 1. Register a Kaggle OAuth app at:
#    https://www.kaggle.com/settings/connected-applications
#    → "New Application"
#    → Redirect URI: http://localhost:8000/api/accounts/oauth/callback
#
# 2. Copy this file to .env and fill in the values below.

KAGGLE_CLIENT_ID=your_kaggle_oauth_client_id
KAGGLE_CLIENT_SECRET=your_kaggle_oauth_client_secret

# URL of THIS backend — used to build the OAuth callback URL
BACKEND_URL=http://localhost:8000

# URL of the frontend — used to redirect back after login
FRONTEND_URL=http://localhost:5173
